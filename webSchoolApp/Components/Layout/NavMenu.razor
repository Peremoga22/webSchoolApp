@rendermode InteractiveServer
@implements IDisposable

@inject NavigationManager NavigationManager

<div class="header-nav">
    <button type="button"
            class="nav-burger @(menuOpen ? "nav-burger--open" : "")"
            aria-label="@(menuOpen ? "Закрити меню" : "Відкрити меню")"
            aria-expanded="@menuOpen"
            @onclick="ToggleMenu">
        <span></span>
        <span></span>
        <span></span>
    </button>

    @if (menuOpen)
    {
        <div class="nav-overlay" @onclick="CloseMenu"></div>
    }

    <nav class="nav @(menuOpen ? "nav--open" : "")">
        <NavLink href="" Match="NavLinkMatch.All" @onclick="CloseMenu">Головна</NavLink>
        <NavLink href="counter" @onclick="CloseMenu">Лічильник</NavLink>
        <NavLink href="weather" @onclick="CloseMenu">Погода</NavLink>
        <NavLink href="auth" @onclick="CloseMenu">Авторизація</NavLink>

        <AuthorizeView>
            <Authorized>
                <NavLink href="Account/Manage" @onclick="CloseMenu">@context.User.Identity?.Name</NavLink>
                <form action="Account/Logout" method="post" class="nav-form">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                    <button type="submit" class="nav-link-btn">Вийти</button>
                </form>
            </Authorized>
            <NotAuthorized>
                <NavLink href="Account/Register" @onclick="CloseMenu">Реєстрація</NavLink>
                <NavLink href="Account/Login" @onclick="CloseMenu">Увійти</NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;
    private bool menuOpen;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        menuOpen = false;
        StateHasChanged();
    }

    private void ToggleMenu() => menuOpen = !menuOpen;

    private void CloseMenu() => menuOpen = false;

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
