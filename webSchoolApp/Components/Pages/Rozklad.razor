@page "/rozklad"
@rendermode InteractiveServer

<PageTitle>Розклад — SchoolSpace</PageTitle>

<div class="page-content">
    <div class="page-hero">
        <span class="page-hero-icon">📅</span>
        <h1 class="page-hero-title">Розклад занять</h1>
        <p class="page-hero-lead">Актуальний розклад для кожного класу з можливістю швидкого пошуку.</p>
    </div>

    <section class="section section--compact">
        <div class="schedule-filter">
            <label for="class-select">Оберіть клас:</label>
            <select id="class-select" class="schedule-select" @bind="selectedClass">
                @foreach (var cls in availableClasses)
                {
                    <option value="@cls">@cls</option>
                }
            </select>
        </div>

        <h2 class="section-title">Тижневий розклад <span>@selectedClass</span></h2>

        <div class="schedule-grid">
            @foreach (var day in weekDays)
            {
                <div class="schedule-day">
                    <h3 class="schedule-day-title">@day.Name</h3>
                    @{
                        var lessons = GetLessonsForDay(day.Index);
                    }
                    @if (lessons.Count == 0)
                    {
                        <p class="schedule-empty">Вихідний</p>
                    }
                    else
                    {
                        @foreach (var lesson in lessons)
                        {
                            <div class="schedule-lesson">
                                <span class="schedule-lesson-num">@lesson.Number</span>
                                <div class="schedule-lesson-info">
                                    <strong>@lesson.Subject</strong>
                                    <span>@lesson.Teacher · каб. @lesson.Room</span>
                                    <span class="schedule-lesson-time">@lesson.Time</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </section>

    <section class="section section--compact">
        <h2 class="section-title">Дзвінки <span>школи</span></h2>
        <div class="cards">
            @foreach (var bell in bells)
            {
                <div class="feature-card">
                    <h3>@bell.Number-й урок</h3>
                    <p>@bell.Start – @bell.End</p>
                </div>
            }
        </div>
    </section>
</div>

