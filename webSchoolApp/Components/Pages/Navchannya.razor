@page "/navchannya"

<PageTitle>Навчання — SchoolSpace</PageTitle>

<div class="page-content">
    <div class="page-hero">
        <span class="page-hero-icon">📚</span>
        <h1 class="page-hero-title">Навчання</h1>
        <p class="page-hero-lead">Розклад уроків, домашні завдання та навчальні матеріали для учнів.</p>
    </div>

    <section class="section section--compact">
        <h2 class="section-title">Предмети <span>9-Б</span></h2>
        <div class="cards">
            @foreach (var subject in subjects)
            {
                <div class="feature-card">
                    <div class="card-icon">@subject.Icon</div>
                    <h3>@subject.Name</h3>
                    <p>@subject.Teacher</p>
                    <span class="badge">@subject.LessonsPerWeek уроків/тиждень</span>
                </div>
            }
        </div>
    </section>

    <section class="section section--compact">
        <h2 class="section-title">Домашні <span>завдання</span></h2>
        <div class="data-table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Предмет</th>
                        <th>Завдання</th>
                        <th>Термін здачі</th>
                        <th>Статус</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var hw in homework)
                    {
                        <tr>
                            <td><strong>@hw.Subject</strong></td>
                            <td>@hw.Task</td>
                            <td>@hw.Deadline.ToString("dd.MM.yyyy")</td>
                            <td><span class="status-badge status-badge--@hw.StatusClass">@hw.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="section section--compact">
        <h2 class="section-title">Навчальні <span>матеріали</span></h2>
        <div class="cards">
            @foreach (var material in materials)
            {
                <div class="feature-card">
                    <span class="material-type">@material.Type</span>
                    <h3>@material.Title</h3>
                    <p>@material.Description</p>
                    <a href="@material.Link" class="material-link">Відкрити матеріал →</a>
                </div>
            }
        </div>
    </section>
</div>

@code {
    private sealed record Subject(string Name, string Teacher, string Icon, int LessonsPerWeek);
    private sealed record Homework(string Subject, string Task, DateTime Deadline, string Status, string StatusClass);
    private sealed record Material(string Title, string Description, string Type, string Link);

    private static readonly IReadOnlyList<Subject> subjects =
    [
        new("Математика", "Іваненко О.П.", "🔢", 5),
        new("Українська мова", "Коваленко М.В.", "📝", 4),
