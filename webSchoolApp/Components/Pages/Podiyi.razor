@page "/podiyi"

<PageTitle>Події — SchoolSpace</PageTitle>

<div class="page-content">
    <div class="page-hero">
        <span class="page-hero-icon">🎉</span>
        <h1 class="page-hero-title">Події</h1>
        <p class="page-hero-lead">Шкільні події, олімпіади, екскурсії — усі оголошення в одному місці.</p>
    </div>

    <section class="section section--compact">
        <h2 class="section-title">Найближчі <span>заходи</span></h2>
        <div class="cards">
            @foreach (var evt in upcomingEvents)
            {
                <div class="feature-card event-card">
                    <span class="event-date">@evt.Date.ToString("d MMMM", ukCulture)</span>
                    <h3>@evt.Title</h3>
                    <p>@evt.Description</p>
                    <div class="event-meta">
                        <span>🕐 @evt.Time</span>
                        <span>📍 @evt.Location</span>
                    </div>
                    @if (!string.IsNullOrEmpty(evt.RegistrationLink))
                    {
                        <a href="@evt.RegistrationLink" class="material-link">Зареєструватися →</a>
                    }
                </div>
            }
        </div>
    </section>

    <section class="section section--compact">
        <h2 class="section-title">Олімпіади та <span>конкурси</span></h2>
        <div class="data-table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Назва</th>
                        <th>Предмет</th>
                        <th>Класи</th>
                        <th>Дата</th>
                        <th>Реєстрація</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var olympiad in olympiads)
                    {
                        <tr>
                            <td><strong>@olympiad.Name</strong></td>
                            <td>@olympiad.Subject</td>
                            <td>@olympiad.Grades</td>
                            <td>@olympiad.Date.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (olympiad.RegistrationOpen)
                                {
                                    <span class="status-badge status-badge--active">Відкрита</span>
                                }
                                else
                                {
                                    <span class="status-badge status-badge--done">Завершена</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="section section--compact">
        <h2 class="section-title">Екскурсії та <span>виїзди</span></h2>
        <div class="cards">
            @foreach (var trip in excursions)
            {
                <div class="feature-card">
                    <div class="card-icon">🚌</div>
                    <h3>@trip.Title</h3>
                    <p>@trip.Description</p>
                    <div class="event-meta">
                        <span>📅 @trip.Date.ToString("d MMMM yyyy", ukCulture)</span>
                        <span>👥 @trip.Participants учасників</span>
                    </div>
                </div>
            }
        </div>
    </section>
</div>

@code {
